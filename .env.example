# OpsPilot Environment Variables

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5438/opspilot
DATABASE_HOST=localhost
DATABASE_PORT=5438
DATABASE_NAME=opspilot
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6384/0
REDIS_HOST=localhost
REDIS_PORT=6384
REDIS_DB=0

# HashiCorp Vault
VAULT_ADDR=http://localhost:8201
VAULT_TOKEN=dev-root-token

# Email Notifications
APP_URL=http://localhost:8848
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_SMTP_FROM=OpsPilot <noreply@opspilot.com>
EMAIL_SMTP_USE_TLS=true

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Backend Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:8848,http://localhost:5173

# Frontend Settings
FRONTEND_URL=http://localhost:8848
API_URL=http://localhost:8000

# SaltStack
SALT_API_URL=http://localhost:8000
SALT_API_USERNAME=saltapi
SALT_API_PASSWORD=saltapi

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Background Tasks (Celery)
CELERY_BROKER_URL=redis://localhost:6384/1
CELERY_RESULT_BACKEND=redis://localhost:6384/2

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
