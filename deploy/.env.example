# Copy to deploy/.env and replace generated values before production use.
# docker compose -f docker-compose.prod.yml --env-file deploy/.env up -d --build
#
# Host Caddy: use deploy/Caddyfile on the edge host and reload Caddy.
#   Dev (docker compose --profile dev): proxies /api*, /health, /docs* → :8000; UI → :8848.
#   Prod (docker-compose.prod.yml): replace the handle blocks with a single reverse_proxy 127.0.0.1:18080.

POSTGRES_DB=opspilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-hex-or-url-encoded

DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/opspilot
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

VAULT_URL=http://vault:8200
VAULT_TOKEN=dev-root-token

SECRET_KEY=change-me-min-32-chars
SALT_API_KEY=change-me

APP_URL=https://opspilot.appfinityhub.com
PUBLIC_API_BASE_URL=https://opspilot.appfinityhub.com/api/v1
ALLOWED_ORIGINS=["https://opspilot.appfinityhub.com"]
